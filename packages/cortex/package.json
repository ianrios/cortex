{
  "name": "@ianrios/cortex",
  "version": "0.0.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "The cortex scaffolder: `cortex init` vendors the repo-owned agent-context layer (.ai/ skeleton, AGENTS.md, resolved brickwall config, gate starters) into your repo.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "cortex": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"no lint configured yet\"",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@ianrios/brickwall": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
